# PostgreSQL Database Connection String (asyncpg driver required)
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/rlhf_platform

# Firebase Service Account JSON File Path (set to empty if MOCK_AUTH=true)
FIREBASE_SERVICE_ACCOUNT_JSON=firebase-service-account.json

# API Keys
GROQ_API_KEY=gsk_your_key_here
GEMINI_API_KEY=AIzaSyYourGeminiKeyHere

# Model Configurations (As of June 2026, check documentation for active models)
# E.g., for Groq: qwen-2.5-coder-32b or similar. For Gemini: gemini-2.5-flash or gemini-3.5-flash
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-2.5-flash

# Trajectory Generation Limits
AGENT_MAX_STEPS=8

# Agreement Metrics Calibration
MIN_SHARED_ANNOTATIONS_FOR_KAPPA=5

# CORS Configuration
FRONTEND_ORIGIN=http://localhost:5173

# Bypass Firebase Auth for Local Development / Evaluation
MOCK_AUTH=true
